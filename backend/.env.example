# IELTS Grader API — 环境配置

# API 服务端口
PORT=8000

# DeepSeek API Key（用于评分）
ANTHROPIC_API_KEY=sk-your-key-here

# 管理员 API Key（用于创建用户 key）
ADMIN_API_KEY=ig_admin_change_this_in_production

# 数据库路径（默认 backend/data/saas.db）
# SAAS_DB_PATH=backend/data/saas.db

# 支付模式: manual（收款码） | hupijiao（虎皮椒聚合支付）
PAYMENT_PROVIDER=manual

# 收款码图片路径（manual 模式，放在 backend/static/ 下）
# MANUAL_QR_WECHAT=/static/qr_wechat.jpg
# MANUAL_QR_ALIPAY=/static/qr_alipay.jpg

# 虎皮椒聚合支付（hupijiao 模式）
# HUPIJIAO_APP_ID=your_app_id
# HUPIJIAO_APP_SECRET=your_app_secret
# HUPIJIAO_WEBHOOK_SECRET=your_webhook_secret

# 服务公网地址（用于支付回调）
# APP_URL=https://your-domain.com
